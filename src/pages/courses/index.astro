---
import Base from '../../layouts/Base.astro';

const courses = [
  {
    href: '/olegagapov.com/courses/sql-fundamentals',
    tag: 'SQL',
    title: 'SQL Fundamentals',
    description: 'Learn to query data from scratch. Write real SQL against a live in-browser database — no installs, no accounts.',
    lessons: '1 lesson',
    tech: 'DuckDB',
  },
];
---

<Base title="Courses — Oleg Agapov">
  <div class="min-h-screen bg-cream font-body">
    <main class="max-w-4xl mx-auto px-6 md:px-14 py-10 md:py-16">

      <h1 class="font-display text-4xl tracking-tight mb-2">Courses</h1>
      <p class="text-base text-gray-500 mb-10">Interactive courses with real SQL running in your browser — no setup required.</p>

      <div class="flex flex-col gap-4">
        {courses.map((course) => (
          <a
            href={course.href}
            class="group bg-white rounded-2xl px-8 pt-7 pb-0 no-underline block"
          >
            <!-- Top row -->
            <div class="flex items-center justify-between mb-6">
              <span class="font-mono text-xs bg-cream text-gray-600 px-3 py-1 rounded-full">{course.tag}</span>
              <span class="font-mono text-xs uppercase tracking-widest bg-cream text-gray-500 px-4 py-1 rounded-full">Free</span>
            </div>

            <!-- Title -->
            <h2 class="font-display text-4xl font-normal tracking-tight text-gray-900 mb-3 group-hover:text-terra transition-colors duration-150">
              {course.title}
            </h2>

            <!-- Description -->
            <p class="text-sm text-gray-500 leading-relaxed mb-7 max-w-lg">{course.description}</p>

            <!-- Footer -->
            <div class="flex items-center justify-between border-t border-gray-100 py-4">
              <div class="flex items-center gap-3 text-sm text-gray-500">
                <!-- Lessons -->
                <div class="flex items-center gap-1.5">
                  <span class="w-6 h-6 rounded bg-cream flex items-center justify-center text-gray-400">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                  </span>
                  <span>{course.lessons}</span>
                </div>
                <span class="text-gray-200">·</span>
                <!-- Tech -->
                <div class="flex items-center gap-1.5">
                  <span class="w-6 h-6 rounded bg-cream flex items-center justify-center text-gray-400">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <ellipse cx="12" cy="5" rx="9" ry="3"/>
                      <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                      <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                    </svg>
                  </span>
                  <span>{course.tech}</span>
                </div>
              </div>

              <!-- Arrow -->
              <span class="text-gray-300 group-hover:text-terra transition-colors duration-150 text-base">→</span>
            </div>
          </a>
        ))}
      </div>

    </main>
  </div>
</Base>
