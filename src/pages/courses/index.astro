---
import Base from '../../layouts/Base.astro';

const courses = [
  {
    href: '/olegagapov.com/courses/sql-fundamentals',
    tag: 'SQL · Beginner',
    title: 'SQL Fundamentals',
    description: 'Learn to query data from scratch. Write real SQL against a live in-browser database — no installs, no accounts needed.',
    meta: ['1 lesson', 'DuckDB', 'Free'],
  },
];
---

<Base title="Courses — Oleg Agapov">
  <div class="min-h-screen bg-cream font-body">
    <main class="max-w-4xl mx-auto px-6 md:px-14 py-10 md:py-16">

      <h1 class="font-display text-5xl tracking-tight text-gray-900 mb-3">
        Courses
      </h1>
      <p class="text-base text-gray-500 mb-12 max-w-lg">
        Interactive courses with real code running in your browser.
      </p>

      <div class="flex flex-col gap-4">
        {courses.map((course) => (
          <a
            href={course.href}
            class="group relative flex flex-col gap-3 bg-cream-card border border-cream-border rounded-xl p-7 no-underline overflow-hidden hover:border-terra/40 transition-colors duration-200"
          >
            <!-- terra left accent bar -->
            <div class="absolute left-0 inset-y-0 w-[3px] bg-terra rounded-l-xl opacity-0 group-hover:opacity-100 transition-opacity duration-200"></div>

            <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-stone-400">
              {course.tag}
            </span>

            <div class="flex items-start justify-between gap-4">
              <h2 class="font-display text-2xl font-normal tracking-tight text-gray-900 group-hover:text-terra transition-colors duration-200">
                {course.title}
              </h2>
              <span class="shrink-0 mt-1 text-stone-300 group-hover:text-terra group-hover:translate-x-0.5 transition-all duration-200 text-lg">→</span>
            </div>

            <p class="text-sm text-gray-500 leading-relaxed max-w-xl">
              {course.description}
            </p>

            <div class="flex items-center gap-2 pt-1 font-mono text-[11px] text-stone-400">
              {course.meta.map((item, i) => (
                <>
                  {i > 0 && <span class="text-stone-300">·</span>}
                  <span>{item}</span>
                </>
              ))}
            </div>
          </a>
        ))}
      </div>

    </main>
  </div>
</Base>
