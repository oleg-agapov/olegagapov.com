---
import Base from '../layouts/Base.astro';
---

<Base title="Oleg Agapov — a small page for a careful mind">
  <div class="min-h-screen bg-cream font-body">

    <!-- Nav -->
    <header class="px-14 py-7 border-b border-gray-200">
      <nav class="max-w-3xl flex items-center gap-7 mx-auto">
        {['Home', 'About', 'CV', 'Recipes', 'Courses', 'Contact'].map((link) => (
          <a
            href={`/${link.toLowerCase()}`}
            class="font-display text-lg text-gray-800 hover:text-terra transition-colors"
          >{link}</a>
        ))}
      </nav>
    </header>

    <!-- Main content -->
    <main class="max-w-4xl mx-auto px-14 py-12 flex flex-col gap-8">

      <!-- Row 1: portrait + heading -->
      <div class="flex items-center gap-6">
        <img src="/avatar-oleg.jpg" alt="Oleg Agapov" class="size-32 rounded-full object-cover shrink-0" />
        <h1 class="font-display text-5xl leading-none tracking-tight text-gray-900">
          Hello — I'm <span class="text-terra">Oleg</span>
        </h1>
      </div>

      <!-- Row 2: bio -->
      <p class="text-sm1 leading-relaxed text-gray-500 max-w-3xl">
        Senior Analytics Engineer at <a href="https://www.hiive.com" class="underline underline-offset-2 hover:text-terra transition-colors">Hiive</a>.
        I teach analytics, create courses and <a href="https://olegagapov.gumroad.com/l/cracking-the-analytics-engineering-interview" class="underline underline-offset-2 hover:text-terra transition-colors">books</a>, cook on weekends.
      </p>

      <!-- Row 3: prompt form -->
      <div class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm max-w-3xl">
        <textarea
          placeholder="Ask me anything..."
          rows="2"
          class="font-body w-full bg-transparent text-lg1 leading-relaxed text-gray-800 placeholder-gray-400 outline-none resize-none"
        ></textarea>
        <div class="mt-3 flex items-center justify-between border-t border-gray-100 pt-3">
          <span class="font-mono flex items-center gap-2 text-xs tracking-widest text-gray-400 uppercase">
            <span class="h-1.5 w-1.5 rounded-full bg-terra"></span>
            Oleg's page
          </span>
          <button class="flex items-center gap-1.5 rounded-full bg-terra px-4 py-1.5 text-xs font-medium text-white hover:opacity-90 transition-opacity">
            Ask <span>→</span>
          </button>
        </div>
      </div>

      <!-- Row 4: suggestion pills -->
      <div class="flex justify-center flex-wrap gap-2">
        {[
          'What do you do at Hive?',
          'Recommend a recipe',
          'Tell me about your courses',
          'How can I reach you?',
        ].map((q) => (
          <button class="font-body rounded-full border border-gray-300 bg-transparent px-4 py-1.5 text-xs text-gray-600 hover:border-terra hover:text-gray-800 hover:cursor-pointer transition-colors">
            {q}
          </button>
        ))}
      </div>

    </main>

  </div>
</Base>
