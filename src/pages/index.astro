---
import Base from '../layouts/Base.astro';
import Chat from '../components/Chat.vue';
---

<Base title="Oleg Agapov">
  <div class="min-h-screen bg-cream font-body">

    <!-- Main content -->
    <main class="max-w-4xl mx-auto px-6 md:px-14 py-10 md:py-12 flex flex-col gap-8">

      <!-- Row 1: portrait + heading -->
      <div class="flex items-center gap-5 md:gap-6">
        <img src="/olegagapov.com/avatar-oleg.jpg" alt="Oleg Agapov" class="size-32 rounded-full object-cover object-[center_15%] shrink-0" />
        <h1 class="font-display text-5xl leading-none tracking-tight text-gray-900">
          Hello — I'm <span class="text-terra">Oleg</span>
        </h1>
      </div>

      <!-- Row 2: bio -->
      <p class="text-sm leading-relaxed text-gray-500">
        Senior Analytics Engineer at <a href="https://www.hiive.com" target="_blank" class="underline underline-offset-2 hover:text-terra transition-colors">Hiive</a>.
        I teach analytics, create courses and <a href="https://olegagapov.gumroad.com/l/cracking-the-analytics-engineering-interview" target="_blank" class="underline underline-offset-2 hover:text-terra transition-colors">books</a>, cook on weekends.
      </p>

      <!-- Row 3+4: interactive chat -->
      <Chat client:only="vue" />

    </main>

  </div>
</Base>
