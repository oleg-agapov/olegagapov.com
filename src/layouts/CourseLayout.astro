---
interface Props {
  title: string;
}

const { title } = Astro.props;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SQL Fundamentals — Interactive Course by Oleg Agapov" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-cream text-stone-900 antialiased font-body leading-relaxed">
    <slot />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/olegagapov.com/sw.js');
      }
    </script>
  </body>
</html>
